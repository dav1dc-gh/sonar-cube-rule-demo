{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/sonarqube-rule.schema.json",
  "title": "SonarQube Rule Definition",
  "description": "Schema for validating SonarQube rule JSON files",
  "type": "object",
  "required": [
    "key",
    "name",
    "description",
    "severity",
    "type",
    "status"
  ],
  "properties": {
    "key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
      "description": "Unique rule identifier in kebab-case (e.g., 'sql-injection')",
      "minLength": 3,
      "maxLength": 50
    },
    "name": {
      "type": "string",
      "description": "Human-readable rule name",
      "minLength": 5,
      "maxLength": 100
    },
    "description": {
      "type": "string",
      "description": "Detailed explanation of what the rule detects",
      "minLength": 50,
      "maxLength": 2000
    },
    "severity": {
      "type": "string",
      "enum": [
        "BLOCKER",
        "CRITICAL",
        "MAJOR",
        "MINOR",
        "INFO"
      ],
      "description": "Rule severity level"
    },
    "type": {
      "type": "string",
      "enum": [
        "BUG",
        "VULNERABILITY",
        "CODE_SMELL",
        "SECURITY_HOTSPOT"
      ],
      "description": "Type of issue this rule detects"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "minItems": 1,
      "uniqueItems": true,
      "description": "Tags for categorization and filtering"
    },
    "status": {
      "type": "string",
      "enum": [
        "READY",
        "BETA",
        "DEPRECATED",
        "REMOVED"
      ],
      "description": "Rule lifecycle status"
    },
    "defaultSeverity": {
      "type": "string",
      "enum": [
        "BLOCKER",
        "CRITICAL",
        "MAJOR",
        "MINOR",
        "INFO"
      ],
      "description": "Default severity (should match severity field)"
    },
    "remediation": {
      "type": "object",
      "description": "Remediation guidance for fixing issues",
      "properties": {
        "constantCost": {
          "type": "string",
          "pattern": "^\\d+\\s*(min|h|d)$",
          "description": "Estimated time to fix (e.g., '30min', '1h', '1d')"
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "before",
              "after"
            ],
            "properties": {
              "before": {
                "type": "string",
                "description": "Code example showing the problem"
              },
              "after": {
                "type": "string",
                "description": "Code example showing the fix"
              },
              "language": {
                "type": "string",
                "description": "Programming language of the example"
              }
            }
          },
          "minItems": 1
        }
      }
    },
    "impacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "softwareQuality",
          "severity"
        ],
        "properties": {
          "softwareQuality": {
            "type": "string",
            "enum": [
              "RELIABILITY",
              "SECURITY",
              "MAINTAINABILITY"
            ]
          },
          "severity": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW"
            ]
          }
        }
      }
    },
    "debt": {
      "type": "object",
      "description": "Technical debt calculation parameters",
      "properties": {
        "function": {
          "type": "string",
          "enum": [
            "CONSTANT_ISSUE",
            "LINEAR",
            "LINEAR_OFFSET"
          ]
        },
        "coefficient": {
          "type": "string",
          "pattern": "^\\d+\\s*(min|h|d)$"
        },
        "offset": {
          "type": "string",
          "pattern": "^\\d+\\s*(min|h|d)$"
        }
      }
    },
    "params": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "name",
          "type"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-zA-Z][a-zA-Z0-9]*$"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "defaultValue": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "type": {
            "type": "string",
            "enum": [
              "STRING",
              "INTEGER",
              "BOOLEAN",
              "TEXT",
              "FLOAT"
            ]
          }
        }
      }
    },
    "scope": {
      "type": "string",
      "enum": [
        "MAIN",
        "TEST",
        "ALL"
      ],
      "description": "Code scope where rule applies"
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Programming languages this rule applies to"
    }
  },
  "additionalProperties": false
}